{"translation-revision-date":"","generator":"gNetwork","source":"wp-includes/build/routes/connectors-home/content.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"fa","plural-forms":"nplurals=2; plural=(n != 1);"},"You do not have permission to install plugins. Please ask a site administrator to install them for you.":[""],"Plugins cannot be installed here due to your site configuration. Install them manually using your normal deployment workflow.":[""],"https://wordpress.org/plugins/%s/":["https://fa.wordpress.org/plugins/%s/"],"If the connector you need is not listed, <a>search the plugin directory</a> to see if a connector is available.":[""],"Connectors appear here when you install plugins that use external services. Each plugin registers the API keys it needs, and you manage them all in one place.":[""],"No connectors yet":["\u0647\u0646\u0648\u0632 \u0628\u062f\u0648\u0646 \u0627\u062a\u0635\u0627\u0644"],"All of your API keys and credentials are stored here and shared across plugins. Configure once and use everywhere.":[""],"Control features in the AI plugin":[""],"Activate the AI plugin":["\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u0627\u0641\u0632\u0648\u0646\u0647 \u0647\u0648\u0634\u200c\u0648\u0627\u0631\u0647"],"Install the AI plugin":["\u0646\u0635\u0628 \u0627\u0641\u0632\u0648\u0646\u0647 \u0647\u0648\u0634\u200c\u0648\u0627\u0631\u0647"],"The <strong>AI plugin</strong> can use your AI connectors to generate featured images, alt text, titles, excerpts and more. <a>Learn more</a>":[""],"The <strong>AI plugin</strong> is installed. Connect an AI provider below to generate featured images, alt text, titles, excerpts, and more. <a>Learn more</a>":[""],"The <strong>AI plugin</strong> is ready to use. You can use it to generate featured images, alt text, titles, excerpts and more. <a>Learn more</a>":[""],"Failed to activate the AI plugin.":["\u0627\u06cc\u0646 \u0628\u0631\u06af\u0647 \u067e\u0627\u06a9 \u0646\u0634\u062f."],"AI plugin activated successfully.":["\u062a\u063a\u06cc\u06cc\u0631\u0627\u062a \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0628\u0647 \u0632\u0628\u0627\u0644\u0647\u200c\u062f\u0627\u0646 \u0645\u0646\u062a\u0642\u0644 \u0634\u062f\u0647\u200c\u0627\u0646\u062f."],"Failed to install the AI plugin.":["\u0627\u06cc\u0646 \u0628\u0631\u06af\u0647 \u067e\u0627\u06a9 \u0646\u0634\u062f."],"AI plugin installed and activated successfully.":["\u0646\u0635\u0628 \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0627\u0646\u062c\u0627\u0645 \u0634\u062f."],"Not available":["\u062f\u0631 \u062f\u0633\u062a\u0631\u0633 \u0646\u06cc\u0633\u062a"],"Connected":["\u0645\u062a\u0635\u0644"],"Failed to disconnect %s.":["\u0646\u0627\u0645\u0648\u0641\u0642 \u062f\u0631 \u0630\u062e\u06cc\u0631\u0647 \u0633\u0627\u0632\u06cc \u062e\u0637\u0627."],"%s disconnected.":["\u0627\u062a\u0635\u0627\u0644 %s \u0642\u0637\u0639 \u0634\u062f."],"%s connected successfully.":["\u0628\u0647\u200c\u0631\u0648\u0632\u0631\u0633\u0627\u0646\u06cc \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0628\u0647 \u067e\u0627\u06cc\u0627\u0646 \u0631\u0633\u06cc\u062f."],"Set up":["\u0631\u0627\u0647\u200c\u0627\u0646\u062f\u0627\u0632\u06cc"],"Checking\u2026":["\u0628\u0631\u0631\u0633\u06cc \u2026"],"Failed to activate plugin for %s.":[""],"Plugin for %s activated successfully.":["\u0642\u0644\u0645\u200c\u0647\u0627 \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0646\u0635\u0628 \u0634\u062f\u0646\u062f."],"Failed to install plugin for %s.":[""],"Plugin for %s installed and activated successfully.":["\u0642\u0644\u0645\u200c\u0647\u0627 \u0628\u0627 \u0645\u0648\u0641\u0642\u06cc\u062a \u0646\u0635\u0628 \u0634\u062f\u0646\u062f."],"Connectors":["\u0627\u062a\u0635\u0627\u0644\u0627\u062a"],"Activating\u2026":["\u0641\u0639\u0627\u0644\u200c\u0633\u0627\u0632\u06cc \u2026"],"Installing\u2026":["\u062f\u0631 \u062d\u0627\u0644 \u0646\u0635\u0628 \u2026"],"Learn more":[